<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Articles{% endblock %}</title>

    {# Tailwind CSS v4 via CDN #}
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-50 text-gray-800">

    <nav class="bg-white border-b border-gray-200 px-6 py-4">
        <div class="max-w-2xl mx-auto flex items-center justify-between">
            <a href="{{ path('app_article_index') }}" class="font-bold text-gray-900">
                Articles
            </a>
            <a href="{{ path('app_article_new') }}"
               class="bg-gray-900 text-white text-sm px-4 py-2 rounded-lg hover:bg-gray-700">
                + Nouvel article
            </a>
        </div>
    </nav>

    {% block body %}{% endblock %}

</body>
</html>
